  "contentId": 2,
  "title": "Live Q&A Session",
  "type": "Live",
  "youtubeEmbedUrl": "https://www.youtube.com/embed/live-stream-id",
  "expiryDate": "2024-03-12T10:00:00Z",
  "isLiveActive": true
}

Response for PDF:
{
  "contentId": 3,
  "title": "ASP.NET Core Cheat Sheet",
  "type": "PDF",
  "accessUrl": "/api/content/3/download",
  "expiryDate": "2025-02-12T10:00:00Z",
  "isLiveActive": false
}

